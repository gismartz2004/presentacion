# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================
POSTGRES_USER=perfumeria_user
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_DB=dbfloreria

# ==============================================
# CONFIGURACIÓN DEL PROYECTO
# ==============================================

# --- Web Perfume (Next.js) ---
ECOMMERCE_API_URL=http://ecommerce-be:3001
ADMIN_API_URL=http://api-perfumeria:3001
NEXT_PUBLIC_API_URL=https://ecommerce-api.perfumeriasz.com
PAYPHONE_TOKEN=your_payphone_token_here
DATABASE_URL=postgresql://perfumeria_user:change_this_password_in_production@postgres:5432/perfumeria_db?schema=public

# --- Ecommerce Backend (NestJS) ---
# DATABASE_URL se configurará automáticamente en docker-compose
NODE_ENV=production
PORT=3001

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --- API Admin (Node/Express) ---
# DATABASE_URL se configurará automáticamente en docker-compose
JWT_SECRET=change_this_jwt_secret_in_production_min_32_chars
SESSION_SECRET=change_this_session_secret_in_production
API_KEY=your_api_key_here

# ==============================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ==============================================
# Asegúrate de cambiar todas las contraseñas y secretos
# antes de desplegar en producción
