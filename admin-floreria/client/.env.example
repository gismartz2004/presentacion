# Client Environment Variables (Vite)

# API Configuration
VITE_API_URL=http://localhost:4001/api          # Legacy Express API (puerto 4001)
VITE_URL_IMG=http://localhost:4001              # URL base para imágenes
VITE_BACKEND_URL=http://localhost:3001          # Nuevo NestJS Backend (ecommerce-be, loyalty, CMS - puerto 3001)

# ============================================
# NOTA PARA DESPLIEGUE CON TRAEFIK:
# ============================================
# En producción, ajusta las URLs a tus dominios:
# VITE_API_URL=https://api-admin.perfumeriasz.com/api
# VITE_URL_IMG=https://api-admin.perfumeriasz.com
# VITE_BACKEND_URL=https://api.perfumeriasz.com

# Configura en GitHub Secrets como CLIENT_ENV_PROD con todo el contenido
