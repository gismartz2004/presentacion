<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>¡Tu código de descuento!</title>

  <style>
    .container { max-width: 680px; margin: 0 auto; }
  </style>
</head>

<body style="margin:0;padding:0;background:#f3f6f8;">
  <center style="width:100%;background:#f3f6f8;padding:30px 0;">
    
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="container" width="680" style="width:100%;max-width:680px;">
      <tr>
        <td>

          <!-- CARD -->
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" 
                 style="background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 10px 30px rgba(18,38,63,0.08);">
            
            <!-- HEADER -->
            <tr>
              <td style="padding:20px;background:linear-gradient(90deg,#3c697b,#c1a65c);color:#fff;">
                <table role="presentation" width="100%">
                  <tr>
                    <td style="text-align:right;vertical-align:middle;font-family:Arial,Helvetica,sans-serif;">
                      <div style="font-weight:700;font-size:18px;">¡Gracias por unirte!</div>
                      <div style="font-size:13px;opacity:0.9;margin-top:4px;">Aquí tienes tu recompensa</div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- BODY -->
            <tr>
              <td style="padding:28px 22px;font-family:Arial,Helvetica,sans-serif;color:#3d3d3d;">

                <div style="text-align:center;font-size:20px;font-weight:700;color:#77472b;">
                  🎁 ¡Aquí tienes tu código de descuento exclusivo!
                </div>

                <div style="margin-top:10px;text-align:center;font-size:14px;color:#555;">
                  Gracias por suscribirte. Usa este código en tu próxima compra:
                </div>

                <!-- DISCOUNT BOX -->
                <div style="margin:22px auto 0 auto;text-align:center;">
                  <div style="
                    display:inline-block;
                    background:#e6f7ef;
                    color:#0b6a35;
                    padding:14px 26px;
                    border-radius:12px;
                    font-weight:700;
                    font-size:24px;
                    letter-spacing:1px;
                    border:2px dashed #0b6a35;
                  ">
                    {{discountCode}}
                  </div>
                </div>

                <!-- BUTTON -->
                <div style="text-align:center;margin-top:24px;">
                  <a href="{{storeUrl}}"
                     style="background:#3c697b;padding:12px 20px;color:#fff;text-decoration:none;font-weight:700;border-radius:8px;display:inline-block;">
                    Ir a la tienda
                  </a>
                </div>

              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td style="padding:14px;text-align:center;background:#77472b;color:#fff;font-family:Arial,Helvetica,sans-serif;">
                <div style="font-weight:700;">{{companyName}}</div>
                <div style="margin-top:6px;font-size:13px;">
                  Cualquier duda escríbenos: 
                  <a href="mailto:{{companyEmail}}" style="color:#fff;text-decoration:none;font-weight:700;">
                    {{companyEmail}}
                  </a>
                </div>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>

  </center>
</body>
</html>
